generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  password   String
  role       Role      @default(user)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  laporan    Laporan[]
}

model Laporan {
  id          Int           @id @default(autoincrement())
  user_id     Int
  title       String
  description String
  location    String
  photo       String
  status      StatusLaporan @default(menunggu)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  user        User          @relation(fields: [user_id], references: [id])
}

enum Role {
  user
  admin
}

enum StatusLaporan {
  menunggu
  diproses
  selesai
}